# EXAMPLE CONFIGURATION: The first is to specify  the  locations manually in detail so that the system can store the files in the specified locations.
 This option requires you to set all three variables: UPLOAD_DIR, PROCESSED_DIR, and HISTORY_DB_PATH. 
If any of these are missing, the system will exit with specific error codes.
# UPLOAD_DIR="G:\server_storage\uploads"
# PROCESSED_DIR="G:\server_storage\processed"
# HISTORY_DB_PATH="G:\server_storage\history.json"



# Server Configuration
PORT=3000

# --- STORAGE CONFIGURATION ---
# Choose ONE of the following modes:

# MODE 1: AUTO-GENERATION (Recommended)
# Provide a base path, and the system will create a unique folder with a 16-character random suffix.
# Example: G:\my_projects
BASE_STORAGE_PATH=

# MODE 2: MANUAL SPECIFICATION (Strict Validation)
# All three variables MUST be defined if BASE_STORAGE_PATH is empty.
# If any are missing, the system will exit with specific error codes.
# Error 1100: UPLOAD_DIR missing
# Error 1101: PROCESSED_DIR missing
# Error 9950: HISTORY_DB_PATH missing

UPLOAD_DIR="G:\server_storage\uploads"
PROCESSED_DIR="G:\server_storage\processed"
HISTORY_DB_PATH="G:\server_storage\history.json"




# EXAMPLE CONFIGURATION: The second option system handie it automatically, so you only need to set the base path.
 The system will create a unique folder with a random suffix for each run.
# BASE_STORAGE_PATH="G:\my_projects"
 



# Server Configuration
PORT=3000

# --- STORAGE CONFIGURATION ---
# Choose ONE of the following modes:

# MODE 1: AUTO-GENERATION (Recommended)
# Provide a base path, and the system will create a unique folder with a 16-character random suffix.
# Example: G:\my_projects
BASE_STORAGE_PATH="G:\my_projects"

# MODE 2: MANUAL SPECIFICATION (Strict Validation)
# All three variables MUST be defined if BASE_STORAGE_PATH is empty.
# If any are missing, the system will exit with specific error codes.
# Error 1100: UPLOAD_DIR missing
# Error 1101: PROCESSED_DIR missing
# Error 9950: HISTORY_DB_PATH missing

UPLOAD_DIR=
PROCESSED_DIR=
HISTORY_DB_PATH=
